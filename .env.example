# ============================================================
# RHW Research DB — Environment Variables
# Copy to .env.local for local dev; set directly on the server for production.
# ============================================================

# ── Auth (next-auth) ─────────────────────────────────────────────────────────
# [REQUIRED] Random secret for encrypting session JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-generated-secret-here

# ── Microsoft Entra ID (Azure AD) ────────────────────────────────────────────
# [REQUIRED for production SSO]
# IT checklist for the App Registration:
#   1. Go to Azure Portal → Azure Active Directory → App registrations → New
#   2. Set Redirect URI (Web):
#        https://<your-server-hostname>/api/auth/callback/microsoft-entra-id
#   3. Supported account types: "Accounts in this organizational directory only"
#   4. API permissions: Microsoft Graph → User.Read (delegated) — already default
#   5. Create a client secret under Certificates & secrets
#
# App Registration → Overview:
AZURE_AD_CLIENT_ID=83159ec2-b03e-415f-bf65-5fa7376190fb
AZURE_AD_TENANT_ID=22913123-1e6a-4c00-b1fd-779c28d3a076

# App Registration → Certificates & secrets → New client secret:
AZURE_AD_CLIENT_SECRET=your-azure-client-secret

# ── Database (Azure Postgres) ─────────────────────────────────────────────────
# [REQUIRED] Azure Database for PostgreSQL Flexible Server.
# Format: postgresql://user:password@host.postgres.database.azure.com/dbname?sslmode=require
# Run scripts/setup-db.sql once against this database before first start.
DATABASE_URL=postgresql://rhwadmin:yourpassword@rhw-research.postgres.database.azure.com/rhw_research?sslmode=require

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
# [REQUIRED] Used by the AI Research tab and AI Summary modal.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Admin access ──────────────────────────────────────────────────────────────
# [OPTIONAL] Comma-separated emails that get isAdmin=true in the session.
# Admins can view the audit log via GET /api/research?audit=1
ADMIN_EMAILS=cromine@rhwcpas.com

# ── App URL (production only) ─────────────────────────────────────────────────
# [REQUIRED in production] The public URL the app is served from.
# next-auth uses this to build OAuth callback URLs.
NEXTAUTH_URL=https://rhw-research.yourdomain.com
